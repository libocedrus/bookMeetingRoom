{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "book-meeting-room",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-06",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*"
    ],
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "vars": {
    "FALLBACK_SHOULD_REMIND": "true"
  }
}
